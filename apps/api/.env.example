## Variáveis de Ambiente de Exemplo (.env.example)

# PORTA em que o servidor irá rodar.
PORT="8000"

# Enreço IP para permitir origin no cors
IP_ADDRESS="0.0.0.0"

# Ambiente de execução (development, production, test)
NODE_ENV="development"

# URL de conexão com o banco de dados. 

# Desenvolvimento LOCAL (sem Docker)
# Exemplo SQLite:
# DATABASE_URL="file:./dev.db"

# Exemplo PostgreSQL local:
# DATABASE_URL="postgresql://dev:dev@localhost:5432/ecommerce-belibeli"

# Desenvolvimento / Produção COM DOCKER
# O host DEVE ser o nome do serviço no docker-compose (db)
DATABASE_URL="postgresql://dev:dev@db:5432/ecommerce-belibeli"

# Chaves secretas usada para assinar e verificar tokens JWT.
# Gere chaves longas e complexas para produção.
JWT_ACCESS_SECRET="<GERAR_CHAVE_SECRETA_COMPLEXA>"
JWT_REFRESH_SECRET="<GERAR_CHAVE_SECRETA_COMPLEXA>"

# CEP de origem para cálculo de frete.
SHIPPING_ORIGIN_CEP="12345678"

# URL do front-end para CORS e redirects.
FRONTEND_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="<SEU_GOOGLE_CLIENT_ID>"
GOOGLE_CLIENT_SECRET="<SEU_GOOGLE_CLIENT_SECRET>"

# Stripe
STRIPE_SECRET_KEY="<SUA_STRIPE_SECRET_KEY>"
STRIPE_WEBHOOK_SECRET="<SEU_STRIPE_WEBHOOK_SECRET>"

# Frete grátis — valor mínimo para ativar frete grátis.
FREE_SHIPPING_MIN_VALUE="200"

# Seed — quantidade de produtos/simulação para popular o banco.
SEED_COUNT="1000"

CLOUDINARY_URL="cloudinary://<your_api_key>:<your_api_secret>@CLOUD_NAME"

# Resend — e-mails transacionais
RESEND_KEY="re_<SUA_RESEND_KEY>"