# URL da sua API (back-end)
NEXT_PUBLIC_API_URL="(SUA_URL_API)"

# Ambiente de execução (development, production, test)
NODE_ENV="development"

# Meilisearch (busca no front-end)
NEXT_PUBLIC_MEILI_HOST="(SEU_MEILI_HOST)"
NEXT_PUBLIC_MEILI_SEARCH_KEY="(SUA_MEILI_SEARCH_KEY)"

# JWT (usado no server-side do Next.js para verificar token)
JWT_ACCESS_SECRET="(SEU_JWT_ACCESS_SECRET)"

# Google OAuth
GOOGLE_CLIENT_ID="(SEU_GOOGLE_CLIENT_ID)"